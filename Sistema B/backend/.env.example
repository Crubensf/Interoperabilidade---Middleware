# ─── Sistema B (PET Saúde UBS) — Backend ─────────────────────────
# Copie este arquivo para .env e preencha com seus valores reais.

API_TITLE=PET Saúde
ENV=dev

# Origens permitidas para CORS (separe por virgula se houver mais de uma)
CORS_ORIGINS=http://localhost:5173

# Conexao com o PostgreSQL
# Formato: postgresql+psycopg://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
# Crie o banco antes de iniciar (ex.: createdb pet_ubs)
DATABASE_URL=postgresql+psycopg://usuario:senha@localhost:5432/pet_ubs

# Chave secreta para assinatura dos JWT (gere uma nova!)
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-por-uma-aleatoria-de-64-caracteres

# Tempo de expiracao do token (em minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60
