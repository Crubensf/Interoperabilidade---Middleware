# Endpoints dos sistemas integrados
SISTEMA_A_BASE_URL=http://localhost:5050
SISTEMA_A_API_KEY=

SISTEMA_B_BASE_URL=http://localhost:8000
SISTEMA_B_API_KEY=

# Credenciais para login no Sistema B (FastAPI exige JWT nos endpoints /fhir)
SISTEMA_B_EMAIL=admin@example.com
SISTEMA_B_SENHA=trocar_aqui

# Configuracao do middleware
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/middleware
MIDDLEWARE_PORT=8080
HTTP_TIMEOUT=15
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
SHADOW_PERSIST_READS=true
