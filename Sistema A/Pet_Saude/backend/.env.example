# ─── Sistema A (MediCare) — Backend ──────────────────────────────
# Copie este arquivo para .env e preencha com seus valores reais.

# Credenciais Supabase (obtenha em https://app.supabase.com -> Project Settings -> API)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_KEY=sua-anon-key-aqui

# Porta do backend
# Obs.: no macOS, a porta 5000 é usada pelo AirPlay Receiver (Control Center)
# e causa EADDRINUSE. Usamos 5050 por padrão.
PORT=5050

# URL do frontend (para configuração de CORS)
FRONTEND_URL=http://localhost:5173

# Chave de API para proteger rotas (deixe vazio para desabilitar)
API_KEY=troque-esta-chave-no-deploy
